<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="StudentDraw.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:StudentDraw.Views"
    Title="StudentDraw">

    <TabBar>
        <Tab Title="Losowanie" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}" Route="MainPage" />
        </Tab>
        <Tab Title="Zarządzanie" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate views:ManageClassesPage}" Route="ManageClassesPage" />
        </Tab>
    </TabBar>

</Shell>
